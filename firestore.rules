// ===============================================================
// Assumed Data Model
// ===============================================================
// Collection: users
// Fields:
//   - uid: string (immutable)
//   - role: 'artist' | 'admin' (immutable for artist)
//   - name: string
//   - email: string (immutable)
//   - createdAt: string (immutable)
//
// Collection: submissions
// Fields: uid, title, mainArtist, etc... status, createdAt
//
// Collection: royalties
// Fields: uid, reportMonth, amount, reportLink, createdAt
//
// Collection: withdrawals
// Fields: uid, bankAccount, upiId, amount, status, createdAt
//
// Collection: notifications
// Fields: uid, message, read, createdAt
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
       return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "deadteevr@gmail.com") || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.uid == userId && request.resource.data.role == 'artist') || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && request.resource.data.role == resource.data.role) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && (
        (isDocOwner() && request.resource.data.status == resource.data.status) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /royalties/{royaltyId} {
      allow read: if isDocOwner() || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid && request.resource.data.status == 'Pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow delete: if isAdmin();
    }

    function isValidFeedback(data) {
      return data.uid == request.auth.uid &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.userEmail is string && data.userEmail.size() <= 255 &&
             data.createdAt == request.time &&
             data.keys().hasAll(['uid', 'message', 'createdAt', 'userEmail']) &&
             data.keys().size() == 4;
    }

    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}

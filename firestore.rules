// ===============================================================
// Assumed Data Model
// ===============================================================
// Collection: users
// Fields:
//   - uid: string (immutable)
//   - role: 'artist' | 'admin' (immutable for artist)
//   - name: string
//   - email: string (immutable)
//   - createdAt: string (immutable)
//
// Collection: submissions
// Fields: uid, title, mainArtist, etc... status, createdAt
//
// Collection: royalties
// Fields: uid, reportMonth, amount, reportLink, createdAt
//
// Collection: withdrawals
// Fields: uid, bankAccount, upiId, amount, status, createdAt
//
// Collection: notifications
// Fields: uid, message, read, createdAt
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
       return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }
    
    function isEmailAdmin() {
       return isAuthenticated() && request.auth.token.email == "deadteevr@gmail.com";
    }

    function isAdmin() {
      return isEmailAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isLabelMember(labelId) {
      if (!isAuthenticated() || !isValidId(labelId)) return false;
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.labelId == labelId && (user.role == 'label_owner' || user.role == 'label_manager');
    }

    function isLabelOwner(labelId) {
      if (!isAuthenticated() || !isValidId(labelId)) return false;
      let user = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return user.labelId == labelId && user.role == 'label_owner';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /activity_logs/{logId} {
      allow read, list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow get: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || (
        isAuthenticated() && 
        resource.data.labelId != null && 
        isLabelMember(resource.data.labelId)
      );
      allow list: if isAdmin();
      allow create: if isAuthenticated() && ( 
        (isOwner(userId) && request.resource.data.uid == userId && request.resource.data.role == 'artist') || 
        isAdmin()
      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && (
          // Role is immutable
          request.resource.data.role == resource.data.role &&
          (
            // Allow setting referralCode
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['referralCode']) ||
            // Or allow other updates if subscription isn't changed illegally
            (isAdmin() || request.resource.data.get('subscription', {}) == resource.data.get('subscription', {}))
          )
        )) || 
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /submissions/{submissionId} {
      allow list: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        isAdmin() || 
        (resource.data.labelId != null && isLabelMember(resource.data.labelId))
      );
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        isAdmin() || 
        (resource.data.labelId != null && isLabelMember(resource.data.labelId))
      );
      allow create: if isAuthenticated() && (
        request.resource.data.uid == request.auth.uid ||
        (request.resource.data.labelId != null && isLabelMember(request.resource.data.labelId))
      );
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (request.auth.uid == resource.data.uid && (
          request.resource.data.status == resource.data.status || 
          request.resource.data.status == "Reviewing" || 
          request.resource.data.status == "Pending"
        )) || 
        (resource.data.labelId != null && isLabelMember(resource.data.labelId))
      );
      allow delete: if (
        request.auth.uid == resource.data.uid && 
        (resource.data.status == 'Reviewing' || resource.data.status == 'Changes Required' || resource.data.status == 'Pending')
      ) || isAdmin() || (resource.data.labelId != null && isLabelMember(resource.data.labelId));
    }

    match /labels/{labelId} {
      allow read: if isAdmin() || isLabelMember(labelId);
      allow create: if isAuthenticated() && (isAdmin() || request.resource.data.ownerUid == request.auth.uid);
      allow update: if isAdmin() || isLabelOwner(labelId) || (
        isLabelMember(labelId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['logoUrl', 'branding', 'artistUids'])
      );
      allow delete: if isAdmin() || isLabelOwner(labelId);

      match /activity/{activityId} {
        allow read, list: if isAdmin() || isLabelMember(labelId);
        allow create: if isLabelMember(labelId);
      }
    }
    
    match /royalties/{royaltyId} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isVerified() && request.resource.data.uid == request.auth.uid && request.resource.data.status == 'Pending';
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow list: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow delete: if isAdmin();
    }

    function isValidFeedback(data) {
      return data.uid == request.auth.uid &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 1000 &&
             data.userEmail is string && data.userEmail.size() <= 255 &&
             data.createdAt == request.time &&
             data.keys().hasAll(['uid', 'message', 'createdAt', 'userEmail']) &&
             data.keys().size() == 4;
    }

    match /feedback/{feedbackId} {
      allow list: if isAdmin();
      allow read: if isAdmin();
      allow create: if isAuthenticated(); // Simplified for now to avoid validation issues
      allow update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /requests/{requestId} {
      allow create: if true;
      allow read, list, update, delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow list, read: if isAuthenticated() && (resource.data.referrerUid == request.auth.uid || isAdmin());
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.referrerUid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /rewards/{rewardId} {
      allow list, read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create, update, delete: if isAdmin();
    }
  }
}

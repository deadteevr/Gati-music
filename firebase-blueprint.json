{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user profile, representing common roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The auth ID" },
        "role": { "type": "string", "enum": ["artist", "admin", "label_owner", "label_manager"] },
        "labelId": { "type": "string", "description": "ID of the label if user belongs to one" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "referralCode": { "type": "string", "description": "Unique code for referrals" },
        "createdAt": { "type": "string", "format": "date-time" },
        "subscription": {
          "type": "object",
          "properties": {
            "planType": { "type": "string", "enum": ["Basic", "Monthly", "Yearly", "Label Monthly", "Label Yearly", "Free"] },
            "startDate": { "type": "string" },
            "expiryDate": { "type": "string" },
            "status": { "type": "string", "enum": ["Active", "Expired"] },
            "paymentStatus": { "type": "string" },
            "uploadCount": { "type": "integer" }
          }
        }
      },
      "required": ["uid", "role", "name", "email", "createdAt"]
    },
    "Label": {
      "title": "Label",
      "description": "A music label or organization profile.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerUid": { "type": "string" },
        "logoUrl": { "type": "string" },
        "branding": {
          "type": "object",
          "properties": {
            "primaryColor": { "type": "string" },
            "website": { "type": "string" }
          }
        },
        "artistUids": { "type": "array", "items": { "type": "string" } },
        "managerUids": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerUid", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "A music distribution submission request.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "labelId": { "type": "string", "description": "ID of the label if submitted via label" },
        "managedArtistUid": { "type": "string", "description": "UID of the artist this release belongs to" },
        "releaseType": { "type": "string", "enum": ["Single", "EP", "Album"] },
        "title": { "type": "string", "description": "Release Title (Album or song title)" },
        "mainArtist": { "type": "string" },
        "featuringArtists": { "type": "array", "items": { "type": "string" } },
        "labelName": { "type": "string" },
        "pLine": { "type": "string" },
        "cLine": { "type": "string" },
        "scheduleDate": { "type": "string" },
        "mainSpotifyLink": { "type": "string" },
        "featureSpotifyLinks": { "type": "string" },
        "excludedPlatforms": { "type": "string" },
        "status": { "type": "string", "enum": ["Reviewing", "Processing", "Sent to Stores", "Live"] },
        "coverUrl": { "type": "string" },
        "upc": { "type": "string" },
        "primaryGenre": { "type": "array", "items": { "type": "string" } },
        "secondaryGenre": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "array", "items": { "type": "string" } },
        "copyrightYear": { "type": "string" },
        "productionYear": { "type": "string" },
        "tracks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "audioUrl": { "type": "string" },
              "isrc": { "type": "string" },
              "lyricist": { "type": "string" },
              "composer": { "type": "string" },
              "producer": { "type": "string" },
              "producerSpotify": { "type": "string" },
              "otherCredits": { "type": "string" },
              "isExplicit": { "type": "boolean" },
              "lyrics": { "type": "string" },
              "trackNumber": { "type": "integer" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "title", "mainArtist", "pLine", "cLine", "status", "createdAt"]
    },
    "Royalty": {
      "title": "Royalty",
      "description": "Monthly royalty report for an artist.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "reportMonth": { "type": "string" },
        "amount": { "type": "number" },
        "reportLink": { "type": "string" },
        "streamsBreakdown": { "type": "string", "description": "JSON string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "reportMonth", "amount", "createdAt"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "A withdrawal request from an artist.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "bankAccount": { "type": "string" },
        "upiId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification pushed to the artist dashboard.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "message", "read", "createdAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback, bug reports, and suggestions.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["new", "read", "resolved"] }
      },
      "required": ["uid", "message", "createdAt", "status"]
    },
    "AccountRequest": {
      "title": "AccountRequest",
      "description": "A request from an artist to join the platform.",
      "type": "object",
      "properties": {
        "applicantName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "instagram": { "type": "string" },
        "spotifyLink": { "type": "string" },
        "referralCode": { "type": "string", "description": "Optional code if referred" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["applicantName", "email", "status", "createdAt"]
    },
    "Referral": {
      "title": "Referral",
      "description": "A manual referral submission for review.",
      "type": "object",
      "properties": {
        "referrerUid": { "type": "string" },
        "referrerName": { "type": "string" },
        "artistName": { "type": "string" },
        "instagramUsername": { "type": "string" },
        "email": { "type": "string" },
        "whatsapp": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Reward Unlocked"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["referrerUid", "artistName", "instagramUsername", "email", "status", "createdAt"]
    },
    "Reward": {
      "title": "Reward",
      "description": "A reward earned through referrals.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "type": { "type": "string", "enum": ["free_song", "free_plan_month"] },
        "status": { "type": "string", "enum": ["active", "used"] },
        "earnedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "type", "status", "earnedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Store users"
    },
    "/requests/{requestId}": {
      "schema": { "$ref": "#/entities/AccountRequest" },
      "description": "Store artist account requests"
    },
    "/referrals/{referralId}": {
      "schema": { "$ref": "#/entities/Referral" },
      "description": "Store referral links"
    },
    "/labels/{labelId}": {
      "schema": { "$ref": "#/entities/Label" },
      "description": "Store label information"
    },
    "/labels/{labelId}/activity/{activityId}": {
      "schema": {
        "title": "LabelActivity",
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "description": { "type": "string" },
          "actorUid": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Activity logs for labels"
    },
    "/rewards/{rewardId}": {
      "schema": { "$ref": "#/entities/Reward" },
      "description": "Store earned rewards"
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/Submission" },
      "description": "Store song submissions"
    },
    "/royalties/{royaltyId}": {
      "schema": { "$ref": "#/entities/Royalty" },
      "description": "Store royalty records"
    },
    "/withdrawals/{withdrawalId}": {
      "schema": { "$ref": "#/entities/Withdrawal" },
      "description": "Store withdrawal requests"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Store user notifications"
    },
    "/feedback/{feedbackId}": {
      "schema": { "$ref": "#/entities/Feedback" },
      "description": "Store user feedback"
    }
  }
}
